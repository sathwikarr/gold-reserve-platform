<?xml version='1.0' encoding='utf-8' ?>
<workbook source-build='2023.1.0' source-platform='mac' version='21.4' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <preferences>
    <color-palette name='Gold Theme' type='regular'>
      <color>#D4AF37</color>
      <color>#F44336</color>
      <color>#FF9800</color>
      <color>#2196F3</color>
      <color>#4CAF50</color>
      <color>#9C27B0</color>
      <color>#F7931A</color>
      <color>#A8A9AD</color>
    </color-palette>
  </preferences>
  <datasources>

    <!-- DATASOURCE 1: Gold Price -->
    <datasource caption='Gold Price' name='goldprice' version='21.4'>
      <connection class='textscan' filename='tableau_gold_price.csv' >
        <relation name='tableau_gold_price.csv' table='[tableau_gold_price#csv]' type='table' />
      </connection>
      <aliases enabled='yes' />
      <column datatype='date'    name='[date]'         role='dimension' type='ordinal'   caption='Date' />
      <column datatype='real'    name='[gold_price]'   role='measure'   type='quantitative' caption='Gold Price (USD/oz)' />
      <column datatype='string'  name='[price_bucket]' role='dimension' type='ordinal'   caption='Price Bucket' />
    </datasource>

    <!-- DATASOURCE 2: Jewelry Thresholds -->
    <datasource caption='Jewelry Thresholds' name='jewelrythresholds' version='21.4'>
      <connection class='textscan' filename='tableau_jewelry_thresholds.csv'>
        <relation name='tableau_jewelry_thresholds.csv' table='[tableau_jewelry_thresholds#csv]' type='table' />
      </connection>
      <column datatype='string' name='[country]'                    role='dimension' type='ordinal'      caption='Country' />
      <column datatype='string' name='[company]'                    role='dimension' type='ordinal'      caption='Company' />
      <column datatype='real'   name='[threshold]'                  role='measure'   type='quantitative' caption='Threshold (USD/oz)' />
      <column datatype='string' name='[threshold_label]'            role='dimension' type='ordinal'      caption='Threshold Label' />
      <column datatype='string' name='[sensitivity]'                role='dimension' type='ordinal'      caption='Sensitivity' />
      <column datatype='real'   name='[substitution_rate_at_threshold]' role='measure' type='quantitative' caption='Substitution Rate (%)' />
      <column datatype='real'   name='[latitude]'                   role='dimension' type='quantitative' caption='Latitude'  geo-role='latitude' />
      <column datatype='real'   name='[longitude]'                  role='dimension' type='quantitative' caption='Longitude' geo-role='longitude' />
    </datasource>

    <!-- DATASOURCE 3: Central Bank Summary -->
    <datasource caption='Central Bank Summary' name='cbsummary' version='21.4'>
      <connection class='textscan' filename='tableau_cb_summary.csv'>
        <relation name='tableau_cb_summary.csv' table='[tableau_cb_summary#csv]' type='table' />
      </connection>
      <column datatype='string' name='[price_bucket]'      role='dimension' type='ordinal'      caption='Price Bucket' />
      <column datatype='real'   name='[avg_gld_volume_M]'  role='measure'   type='quantitative' caption='Avg GLD Volume (M)' />
      <column datatype='real'   name='[avg_usd_index]'     role='measure'   type='quantitative' caption='Avg USD Index' />
      <column datatype='string' name='[behavior]'          role='dimension' type='ordinal'      caption='Behavior' />
      <column datatype='string' name='[threshold_zone]'    role='dimension' type='ordinal'      caption='Threshold Zone' />
    </datasource>

    <!-- DATASOURCE 4: Investor Heatmap -->
    <datasource caption='Investor Heatmap' name='investorheatmap' version='21.4'>
      <connection class='textscan' filename='tableau_investor_heatmap.csv'>
        <relation name='tableau_investor_heatmap.csv' table='[tableau_investor_heatmap#csv]' type='table' />
      </connection>
      <column datatype='string' name='[asset]'               role='dimension' type='ordinal'      caption='Asset' />
      <column datatype='string' name='[price_bucket]'        role='dimension' type='ordinal'      caption='Price Bucket' />
      <column datatype='real'   name='[avg_monthly_return]'  role='measure'   type='quantitative' caption='Avg Monthly Return (%)' />
    </datasource>

    <!-- DATASOURCE 5: Tech Summary -->
    <datasource caption='Tech Summary' name='techsummary' version='21.4'>
      <connection class='textscan' filename='tableau_tech_summary.csv'>
        <relation name='tableau_tech_summary.csv' table='[tableau_tech_summary#csv]' type='table' />
      </connection>
      <column datatype='string' name='[price_bucket]'                role='dimension' type='ordinal'      caption='Price Bucket' />
      <column datatype='real'   name='[avg_gold_palladium_ratio]'    role='measure'   type='quantitative' caption='Gold/Palladium Ratio' />
      <column datatype='real'   name='[avg_gold_silver_ratio]'       role='measure'   type='quantitative' caption='Gold/Silver Ratio' />
      <column datatype='real'   name='[months]'                      role='measure'   type='quantitative' caption='Months' />
    </datasource>

  </datasources>

  <worksheets>

    <!-- SHEET 1: Gold Price Timeline -->
    <worksheet name='1. Gold Price Timeline'>
      <table>
        <view>
          <datasources>
            <datasource caption='Gold Price' name='goldprice' />
          </datasources>
          <datasource-dependencies datasource='goldprice'>
            <column datatype='date'   name='[date]'       role='dimension' type='ordinal' />
            <column datatype='real'   name='[gold_price]' role='measure'   type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[goldprice].[date]' />
          <slices>
            <column>[goldprice].[date]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='color' field='[goldprice].[gold_price]' type='palette'>
              <map to='#D4AF37' />
            </encoding>
          </style-rule>
        </style>
        <panes>
          <pane>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Line' />
            <encodings>
              <column field='[goldprice].[date]'       type='quant' />
              <row    field='[goldprice].[gold_price]' type='quant' />
            </encodings>
          </pane>
        </panes>
        <rows>[goldprice].[gold_price]</rows>
        <cols>[goldprice].[date]</cols>
      </table>
      <simple-id uuid='{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}' />
    </worksheet>

    <!-- SHEET 2: Jewelry Thresholds by Country -->
    <worksheet name='2. Jewelry Thresholds by Country'>
      <table>
        <view>
          <datasources>
            <datasource caption='Jewelry Thresholds' name='jewelrythresholds' />
          </datasources>
          <datasource-dependencies datasource='jewelrythresholds'>
            <column datatype='string' name='[country]'     role='dimension' type='ordinal' />
            <column datatype='real'   name='[threshold]'   role='measure'   type='quantitative' />
            <column datatype='string' name='[sensitivity]' role='dimension' type='ordinal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <panes>
          <pane>
            <mark class='Bar' />
            <encodings>
              <column field='[jewelrythresholds].[country]'     type='nominal' />
              <row    field='[jewelrythresholds].[threshold]'   type='quant' />
              <color  field='[jewelrythresholds].[sensitivity]' type='nominal' />
              <label  field='[jewelrythresholds].[threshold]'   type='quant' />
            </encodings>
          </pane>
        </panes>
        <rows>[jewelrythresholds].[threshold]</rows>
        <cols>[jewelrythresholds].[country]</cols>
      </table>
      <simple-id uuid='{B2C3D4E5-F6A7-8901-BCDE-F12345678901}' />
    </worksheet>

    <!-- SHEET 3: Country Map -->
    <worksheet name='3. Country Map — Sensitivity'>
      <table>
        <view>
          <datasources>
            <datasource caption='Jewelry Thresholds' name='jewelrythresholds' />
          </datasources>
          <datasource-dependencies datasource='jewelrythresholds'>
            <column datatype='real'   name='[latitude]'    role='dimension' type='quantitative' geo-role='latitude' />
            <column datatype='real'   name='[longitude]'   role='dimension' type='quantitative' geo-role='longitude' />
            <column datatype='string' name='[country]'     role='dimension' type='ordinal' />
            <column datatype='string' name='[sensitivity]' role='dimension' type='ordinal' />
            <column datatype='real'   name='[substitution_rate_at_threshold]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <panes>
          <pane>
            <mark class='Shape' />
            <encodings>
              <column field='[jewelrythresholds].[longitude]'   type='quant' />
              <row    field='[jewelrythresholds].[latitude]'    type='quant' />
              <color  field='[jewelrythresholds].[sensitivity]' type='nominal' />
              <size   field='[jewelrythresholds].[substitution_rate_at_threshold]' type='quant' />
              <label  field='[jewelrythresholds].[country]'    type='nominal' />
            </encodings>
          </pane>
        </panes>
        <rows>[jewelrythresholds].[latitude]</rows>
        <cols>[jewelrythresholds].[longitude]</cols>
      </table>
      <simple-id uuid='{C3D4E5F6-A7B8-9012-CDEF-012345678902}' />
    </worksheet>

    <!-- SHEET 4: Investor Rotation Heatmap -->
    <worksheet name='4. Investor Rotation Heatmap'>
      <table>
        <view>
          <datasources>
            <datasource caption='Investor Heatmap' name='investorheatmap' />
          </datasources>
          <datasource-dependencies datasource='investorheatmap'>
            <column datatype='string' name='[asset]'              role='dimension' type='ordinal' />
            <column datatype='string' name='[price_bucket]'       role='dimension' type='ordinal' />
            <column datatype='real'   name='[avg_monthly_return]' role='measure'   type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <panes>
          <pane>
            <mark class='Square' />
            <encodings>
              <column field='[investorheatmap].[price_bucket]'       type='nominal' />
              <row    field='[investorheatmap].[asset]'              type='nominal' />
              <color  field='[investorheatmap].[avg_monthly_return]' type='quant' />
              <label  field='[investorheatmap].[avg_monthly_return]' type='quant' />
            </encodings>
          </pane>
        </panes>
        <rows>[investorheatmap].[asset]</rows>
        <cols>[investorheatmap].[price_bucket]</cols>
      </table>
      <simple-id uuid='{D4E5F6A7-B8C9-0123-DEF0-123456789003}' />
    </worksheet>

    <!-- SHEET 5: Central Bank Activity -->
    <worksheet name='5. Central Bank Activity'>
      <table>
        <view>
          <datasources>
            <datasource caption='Central Bank Summary' name='cbsummary' />
          </datasources>
          <datasource-dependencies datasource='cbsummary'>
            <column datatype='string' name='[price_bucket]'     role='dimension' type='ordinal' />
            <column datatype='real'   name='[avg_gld_volume_M]' role='measure'   type='quantitative' />
            <column datatype='string' name='[threshold_zone]'   role='dimension' type='ordinal' />
            <column datatype='string' name='[behavior]'         role='dimension' type='ordinal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <panes>
          <pane>
            <mark class='Bar' />
            <encodings>
              <column field='[cbsummary].[price_bucket]'     type='nominal' />
              <row    field='[cbsummary].[avg_gld_volume_M]' type='quant' />
              <color  field='[cbsummary].[threshold_zone]'   type='nominal' />
              <label  field='[cbsummary].[avg_gld_volume_M]' type='quant' />
            </encodings>
          </pane>
        </panes>
        <rows>[cbsummary].[avg_gld_volume_M]</rows>
        <cols>[cbsummary].[price_bucket]</cols>
      </table>
      <simple-id uuid='{E5F6A7B8-C9D0-1234-EF01-234567890004}' />
    </worksheet>

    <!-- SHEET 6: Tech Gold/Palladium Ratio -->
    <worksheet name='6. Tech Substitution Ratio'>
      <table>
        <view>
          <datasources>
            <datasource caption='Tech Summary' name='techsummary' />
          </datasources>
          <datasource-dependencies datasource='techsummary'>
            <column datatype='string' name='[price_bucket]'             role='dimension' type='ordinal' />
            <column datatype='real'   name='[avg_gold_palladium_ratio]' role='measure'   type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <panes>
          <pane>
            <mark class='Bar' />
            <encodings>
              <column field='[techsummary].[price_bucket]'             type='nominal' />
              <row    field='[techsummary].[avg_gold_palladium_ratio]' type='quant' />
              <label  field='[techsummary].[avg_gold_palladium_ratio]' type='quant' />
            </encodings>
          </pane>
        </panes>
        <rows>[techsummary].[avg_gold_palladium_ratio]</rows>
        <cols>[techsummary].[price_bucket]</cols>
      </table>
      <simple-id uuid='{F6A7B8C9-D0E1-2345-F012-345678900005}' />
    </worksheet>

  </worksheets>

  <dashboards>
    <dashboard name='Gold Substitution Dashboard'>
      <style />
      <size maxheight='2000' maxwidth='2000' minheight='600' minwidth='800' />
      <zones>
        <zone h='98000' id='1' type='layout-basic' w='98000' x='1000' y='1000'>
          <zone h='48000' id='2' type='layout-flow' w='98000' x='1000' y='1000'>
            <zone h='48000' id='3' name='1. Gold Price Timeline' type='sheet' w='98000' x='1000' y='1000' />
          </zone>
          <zone h='25000' id='4' type='layout-flow' w='98000' x='1000' y='50000'>
            <zone h='25000' id='5' name='2. Jewelry Thresholds by Country' type='sheet' w='49000' x='1000' y='50000' />
            <zone h='25000' id='6' name='3. Country Map — Sensitivity'     type='sheet' w='49000' x='50000' y='50000' />
          </zone>
          <zone h='25000' id='7' type='layout-flow' w='98000' x='1000' y='76000'>
            <zone h='25000' id='8'  name='4. Investor Rotation Heatmap' type='sheet' w='32000' x='1000'  y='76000' />
            <zone h='25000' id='9'  name='5. Central Bank Activity'     type='sheet' w='32000' x='34000' y='76000' />
            <zone h='25000' id='10' name='6. Tech Substitution Ratio'   type='sheet' w='32000' x='67000' y='76000' />
          </zone>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='2000' maxwidth='2000' minheight='400' minwidth='300' sizing-mode='vscroll' />
        </devicelayout>
      </devicelayouts>
      <simple-id uuid='{A7B8C9D0-E1F2-3456-0123-456789000006}' />
    </dashboard>
  </dashboards>

  <windows source-id='{A7B8C9D0-E1F2-3456-0123-456789000006}'>
    <window class='dashboard' maximized='true' name='Gold Substitution Dashboard'>
      <viewpoint />
      <simple-id uuid='{B8C9D0E1-F2A3-4567-1234-567890000007}' />
    </window>
  </windows>

</workbook>
