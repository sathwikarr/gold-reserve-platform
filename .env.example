# Gold Reserve Platform — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Database (optional — for PostgreSQL layer) ──────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gold_reserve_db

# ── API Keys (optional — for live data refresh) ─────────────────────────────
# World Bank API — no key needed (public)
# IMF API — no key needed (public)

# ── GDELT / News (optional — for NLP pipeline) ──────────────────────────────
GDELT_API_KEY=your_gdelt_api_key_here

# ── Streamlit Cloud (set in app secrets, not here) ──────────────────────────
# DATABASE_URL=your_cloud_db_url
