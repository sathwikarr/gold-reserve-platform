# Virtual environment
.venv/

# Environment variables
.env

# Python cache
__pycache__/
*.py[cod]
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Data — raw and staging stay local (large/sensitive files)
data/raw/*
data/staging/*
!data/raw/.gitkeep
!data/staging/.gitkeep

# Curated data IS committed — Streamlit Cloud needs it to run the app
# !data/curated/*  ← intentionally NOT ignored

# macOS
.DS_Store

# VS Code
.vscode/
.virtual_documents/
anaconda_projects/
